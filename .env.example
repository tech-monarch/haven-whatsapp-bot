# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (same DB as backend) ───────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/haven

# ─── AI — Gemini (add both keys for failover) ─────────────────────────────────
GEMINI_API_KEY_1=your_primary_gemini_api_key
GEMINI_API_KEY_2=your_secondary_gemini_api_key
# Optional: override model
GEMINI_MODEL=gemini-1.5-flash

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
# The phone number the bot SIM is registered with (digits only, with country code)
BOT_PHONE_NUMBER=2348012345678

# ─── Backend integration ──────────────────────────────────────────────────────
# URL of the backend API
BACKEND_BASE_URL=http://localhost:3001
# Must match INTERNAL_API_KEY in the backend's .env
INTERNAL_API_KEY=generate_with__openssl_rand_hex_32

# ─── Admin numbers ────────────────────────────────────────────────────────────
ADMIN_NUMBERS=2348012345678,2348098765432
