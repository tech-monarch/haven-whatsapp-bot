# Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Gemini model to use (defaults to gemini-1.5-flash if unset)
GEMINI_MODEL=gemini-1.5-flash

# PostgreSQL connection string.
# If this is NOT set, the app automatically falls back to in-memory mock artisan data.
# Example: postgres://user:password@localhost:5432/artisan_marketplace
DATABASE_URL=

# Port for the optional health-check HTTP server
PORT=3000

# Self-ping URL (prevents server hibernation on Render free tier).
# On Render this is set automatically via the RENDER_EXTERNAL_URL environment variable.
# On other platforms, set this to your public URL (e.g. https://your-app.onrender.com).
# Leave blank on local dev — it will fall back to http://localhost:PORT.
RENDER_EXTERNAL_URL=

# Comma-separated list of admin phone numbers (with country code, no +), used for /admin commands (optional)
ADMIN_NUMBERS=

# Log level: trace | debug | info | warn | error | silent
LOG_LEVEL=info
