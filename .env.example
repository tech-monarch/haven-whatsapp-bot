# ── Groq AI ──────────────────────────────────────────────────────────────────
# Single key (most common case):
GROQ_API_KEY=your_groq_api_key
# Optional: multiple keys for automatic rotation on rate-limit/quota errors.
# If any GROQ_API_KEY_n is set, GROQ_API_KEY above is ignored.
# GROQ_API_KEY_1=your_first_groq_key
# GROQ_API_KEY_2=your_second_groq_key

# Model — compound-beta-mini is fast, tool-aware, and ideal for this bot.
# You can override with any Groq model (e.g. llama-3.3-70b-versatile).
GROQ_MODEL=compound-beta-mini

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info

# ── WhatsApp pairing ───────────────────────────────────────────────────────────
WA_PHONE_NUMBER=234XXXXXXXXXX
SESSION_PATH=./whatsapp-session

# ── Backend integration ────────────────────────────────────────────────────────
BACKEND_BASE_URL=http://localhost:3001
INTERNAL_API_KEY=your_secret_key

# ── Render keep-alive ──────────────────────────────────────────────────────────
RENDER_EXTERNAL_URL=https://your-app.onrender.com

# ── Admin phones (optional) ────────────────────────────────────────────────────
ADMIN_NUMBERS=234XXXXXXXXXX,234XXXXXXXXXX

# ── Paystack (optional) ────────────────────────────────────────────────────────
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret
